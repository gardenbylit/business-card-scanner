# Environment variables for ScanIt
# AdMob Ad Unit IDs - Replace with your actual IDs from AdMob Console

# Banner Ad Unit (for header/footer ads)
BANNER_AD_UNIT_ID=ca-app-pub-1434350247953949/5507555074

# Interstitial Ad Unit (for full-screen ads)
INTERSTITIAL_AD_UNIT_ID=ca-app-pub-3940256099942544/1033173712

# Rewarded Ad Unit (for video ads with rewards)
REWARDED_AD_UNIT_ID=ca-app-pub-1434350247953949/3622758226

# Firebase Configuration
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY_HERE
FIREBASE_PROJECT_ID=scanit
FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID_HERE
FIREBASE_APP_ID=YOUR_APP_ID_HERE

# AdMob App ID (from AdMob Console)
ADMOB_APP_ID=ca-app-pub-1434350247953949~1328636918

# Google Play Console
GOOGLE_PLAY_PACKAGE_NAME=com.ScanIt

# App Configuration
APP_NAME=ScanIt
APP_VERSION=1.0.0
ENVIRONMENT=production
